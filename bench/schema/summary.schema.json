{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/claude-crew/bench/summary.schema.json",
  "title": "Benchmark Summary",
  "type": "object",
  "required": [
    "schema_version",
    "mode",
    "runner",
    "generated_at",
    "source_ref",
    "source_sha",
    "task_glob",
    "totals",
    "rates",
    "median_runtime_seconds",
    "tasks"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "enum": [
        "mock",
        "command"
      ]
    },
    "runner": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "source_ref": {
      "type": "string"
    },
    "source_sha": {
      "type": "string"
    },
    "task_glob": {
      "type": "string"
    },
    "totals": {
      "type": "object",
      "required": [
        "tasks",
        "passed",
        "clean_passed",
        "completed",
        "verification_required",
        "tests_run",
        "tests_passed",
        "review_required",
        "review_present",
        "docs_required",
        "docs_updated",
        "recovered_tasks",
        "timeout_recovered",
        "max_turns_recovered",
        "summary_repaired",
        "policy_violations",
        "tool_failures"
      ],
      "properties": {
        "tasks": { "type": "integer", "minimum": 0 },
        "passed": { "type": "integer", "minimum": 0 },
        "clean_passed": { "type": "integer", "minimum": 0 },
        "completed": { "type": "integer", "minimum": 0 },
        "verification_required": { "type": "integer", "minimum": 0 },
        "tests_run": { "type": "integer", "minimum": 0 },
        "tests_passed": { "type": "integer", "minimum": 0 },
        "review_required": { "type": "integer", "minimum": 0 },
        "review_present": { "type": "integer", "minimum": 0 },
        "docs_required": { "type": "integer", "minimum": 0 },
        "docs_updated": { "type": "integer", "minimum": 0 },
        "recovered_tasks": { "type": "integer", "minimum": 0 },
        "timeout_recovered": { "type": "integer", "minimum": 0 },
        "max_turns_recovered": { "type": "integer", "minimum": 0 },
        "summary_repaired": { "type": "integer", "minimum": 0 },
        "policy_violations": { "type": "integer", "minimum": 0 },
        "tool_failures": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "rates": {
      "type": "object",
      "required": [
        "task_pass_rate",
        "clean_pass_rate",
        "completion_rate",
        "verification_rate",
        "verification_pass_rate",
        "review_compliance_rate",
        "docs_compliance_rate",
        "recovered_task_rate",
        "summary_repair_rate"
      ],
      "properties": {
        "task_pass_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "clean_pass_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "completion_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "verification_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "verification_pass_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "review_compliance_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "docs_compliance_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "recovered_task_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "summary_repair_rate": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "median_runtime_seconds": {
      "type": "number",
      "minimum": 0
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "task_id",
          "status",
          "completed",
          "verification_required",
          "tests_run",
          "tests_passed",
          "review_required",
          "review_present",
          "docs_required",
          "docs_updated",
          "policy_violations",
          "tool_failures",
          "runtime_seconds",
          "notes"
        ],
        "properties": {
          "task_id": { "type": "string" },
          "status": { "type": "string" },
          "completed": { "type": "boolean" },
          "verification_required": { "type": "boolean" },
          "tests_run": { "type": "boolean" },
          "tests_passed": { "type": "boolean" },
          "review_required": { "type": "boolean" },
          "review_present": { "type": "boolean" },
          "docs_required": { "type": "boolean" },
          "docs_updated": { "type": "boolean" },
          "policy_violations": { "type": "integer", "minimum": 0 },
          "tool_failures": { "type": "integer", "minimum": 0 },
          "runtime_seconds": { "type": "number", "minimum": 0 },
          "notes": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
