[
  {
    "name": "feature_shared_state_progression",
    "session_id": "scenario-feature-shared-state",
    "steps": [
      {
        "name": "session_start_detects_node_scripts",
        "script": "claudecfg/hooks/session-start.sh",
        "stdin": "tests/hooks/fixtures/session_start_node.json",
        "cwd": "tests/hooks/projects/node-app",
        "env": {
          "CLAUDE_ENV_FILE": "__CASE_TMP__/claude.env"
        },
        "expect_exit": 0,
        "stdout_jq": ".hookSpecificOutput.hookEventName == \"SessionStart\" and (.hookSpecificOutput.additionalContext | contains(\"test=npm run test\")) and (.hookSpecificOutput.additionalContext | contains(\"lint=npm run lint\")) and (.hookSpecificOutput.additionalContext | contains(\"build=npm run build\"))",
        "file_assertions": [
          {
            "path": "__CASE_TMP__/claude.env",
            "regex": "CLAUDE_SDLC_PROFILE=hook-gated"
          },
          {
            "path": "__CASE_TMP__/claude.env",
            "regex": "PROJECT_TEST_CMD=\"npm run test\""
          },
          {
            "path": "__CASE_TMP__/claude.env",
            "regex": "PROJECT_LINT_CMD=\"npm run lint\""
          },
          {
            "path": "__CASE_TMP__/claude.env",
            "regex": "PROJECT_BUILD_CMD=\"npm run build\""
          }
        ],
        "state_jq": ".detected_test_command == \"npm run test\" and .detected_lint_command == \"npm run lint\" and .detected_build_command == \"npm run build\""
      },
      {
        "name": "user_prompt_submit_classifies_feature",
        "script": "claudecfg/hooks/user-prompt-submit.sh",
        "stdin": "tests/hooks/fixtures/user_prompt_feature.json",
        "expect_exit": 0,
        "stdout_jq": ".hookSpecificOutput.hookEventName == \"UserPromptSubmit\" and (.hookSpecificOutput.additionalContext | contains(\"successful verification or @t\"))",
        "state_jq": ".task_type == \"feature\" and ((.required_subagents | sort) == [\"cr\", \"t\"]) and .required_subagent_any_of == [[\"e\", \"a\"]]"
      },
      {
        "name": "post_edit_write_marks_code_change",
        "script": "claudecfg/hooks/post-edit-write.sh",
        "stdin": "tests/hooks/fixtures/post_edit_write_code.json",
        "expect_exit": 0,
        "stdout_jq": ".hookSpecificOutput.hookEventName == \"PostToolUse\" and (.hookSpecificOutput.additionalContext | contains(\"requires verification\"))",
        "state_jq": ".edited == true and .code_changed == true and .docs_changed == false and ((.files | index(\"src/app.py\")) != null)"
      },
      {
        "name": "task_completed_blocks_without_successful_verification",
        "script": "claudecfg/hooks/task-completed.sh",
        "stdin": "tests/hooks/fixtures/task_completed_incomplete.json",
        "expect_exit": 2,
        "stderr_regex": "no successful test command"
      },
      {
        "name": "post_bash_marks_tests_ok",
        "script": "claudecfg/hooks/post-bash.sh",
        "stdin": "tests/hooks/fixtures/post_bash_test_success.json",
        "expect_exit": 0,
        "stdout_jq": ".hookSpecificOutput.hookEventName == \"PostToolUse\" and (.hookSpecificOutput.additionalContext | contains(\"Successful verification command\"))",
        "state_jq": ".tests_ok == true and .tests_failed == false and .last_test_command == \"pytest -q\""
      },
      {
        "name": "subagent_start_code_reviewer",
        "script": "claudecfg/hooks/subagent-start.sh",
        "stdin": "tests/hooks/fixtures/subagent_start_code_reviewer.json",
        "expect_exit": 0,
        "stdout_jq": ".hookSpecificOutput.hookEventName == \"SubagentStart\" and (.hookSpecificOutput.additionalContext | contains(\"@cr\"))",
        "state_jq": ".subagent_start_count == 1 and .subagents_started == [\"cr\"]"
      },
      {
        "name": "subagent_start_explorer_scope",
        "script": "claudecfg/hooks/subagent-start.sh",
        "stdin": "tests/hooks/fixtures/subagent_start_second_explorer_scope.json",
        "expect_exit": 0,
        "stdout_jq": ".hookSpecificOutput.hookEventName == \"SubagentStart\" and (.hookSpecificOutput.additionalContext | contains(\"Parallel same-role handoffs are allowed\"))",
        "state_jq": ".subagent_start_count == 2 and (.subagents_started | sort) == [\"cr\", \"e\"] and .subagent_instance_count_by_role.cr == 1 and .subagent_instance_count_by_role.e == 1 and (.subagent_events | length) == 2"
      },
      {
        "name": "task_completed_allows_with_verification_and_roles",
        "script": "claudecfg/hooks/task-completed.sh",
        "stdin": "tests/hooks/fixtures/task_completed_feature_roles_satisfied.json",
        "expect_exit": 0
      },
      {
        "name": "stop_guard_allows_with_complete_summary",
        "script": "claudecfg/hooks/stop-guard.sh",
        "stdin": "tests/hooks/fixtures/stop_guard_key_files_changed_label.json",
        "expect_exit": 0,
        "state_jq": ".stop_block_count == 0 and .stop_block_reason == \"\" and .stop_block_message == \"\""
      }
    ]
  },
  {
