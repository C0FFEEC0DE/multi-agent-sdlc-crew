      {
        "name": "session_end_minimal",
        "script": "claudecfg/hooks/session-end.sh",
        "stdin": "tests/hooks/fixtures/session_end_minimal.json",
        "expect_exit": 0,
        "file_assertions": [
          {
            "path": "__CASE_HOME__/.claude/logs/session-index.jsonl",
            "regex": "\"session_id\"[[:space:]]*:[[:space:]]*\"scenario-session-logging\""
          },
          {
            "path": "__CASE_HOME__/.claude/logs/session-index.jsonl",
            "regex": "\"cwd\"[[:space:]]*:[[:space:]]*\"\""
          },
          {
            "path": "__CASE_HOME__/.claude/logs/session-index.jsonl",
            "regex": "\"transcript_path\"[[:space:]]*:[[:space:]]*\"\""
          },
          {
