        "expect_exit": 0,
        "file_assertions": [
          {
            "path": "__CASE_HOME__/.claude/logs/pre-compact.jsonl",
            "regex": "\"session_id\"[[:space:]]*:[[:space:]]*\"scenario-session-logging\""
          },
          {
            "path": "__CASE_HOME__/.claude/logs/pre-compact.jsonl",
            "regex": "\"trigger\"[[:space:]]*:[[:space:]]*\"\""
          }
        ]
      },
      {
        "name": "post_compact_minimal",
        "script": "claudecfg/hooks/post-compact.sh",
        "stdin": "tests/hooks/fixtures/post_compact_minimal.json",
        "expect_exit": 0,
        "file_assertions": [
          {
            "path": "__CASE_HOME__/.claude/logs/post-compact.jsonl",
            "regex": "\"session_id\"[[:space:]]*:[[:space:]]*\"scenario-session-logging\""
          },
          {
            "path": "__CASE_HOME__/.claude/logs/post-compact.jsonl",
            "regex": "\"compact_summary\"[[:space:]]*:[[:space:]]*\"\""
          }
        ]
