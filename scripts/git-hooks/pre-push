#!/bin/bash
# Optional local pre-push hook: fast grep-based secret scan of the commits
# being pushed. Opt-in — install with `scripts/install-git-hooks.sh`.
#
# This is a fast first line of defense; the authoritative scan is TruffleHog in
# CI(.github/workflows/security-scan.yml). A match blocks the push so you can
# review before anything leaves your machine.

set -euo pipefail

# Patterns that almost always indicate a real secret. Kept short and
# high-signal to avoid noisy false positives on a pre-push gate.
SECRET_PATTERN='(-----BEGIN [A-Z ]*PRIVATE KEY-----|sk-[a-zA-Z0-9]{20,}|ghp_[0-9A-Za-z]{36,}|gho_[0-9A-Za-z]{36,}|glpat-[0-9a-zA-Z_-]{20,}|xox[baprs]-[0-9a-zA-Z-]+|AKIA[0-9A-Z]{16}|AIza[0-9A-Za-z_-]{35})'

# Secret-bearing path segments/names. Anchored to path boundaries so a normal
# source path like src/credentials.go is not matched; we only flag files whose
# name or a path segment is exactly credentials/secrets, or a secret extension.
SECRET_PATH_REGEX='(^|/)(credentials|secrets)(/|$)|\.(env|pem|key|p12|pfx|keystore|jks)(\.|$)'

status=0

while read -r _local_ref _local_sha _remote_ref _remote_sha; do
    [ -z "${_local_sha:-}" ] && continue

    # Commits being pushed = those reachable from _local_sha but not from any
    # remote. Using "--not --remotes" works for both fast-forward pushes
    # (remote_sha set; its tip is on a remote so it's excluded) and new branches
    # (remote_sha is all-zeros / unset; no remote holds these commits yet, so
    # all local commits are scanned). Over-scanning is fine for a secret gate;
    # we never want to under-scan.
    new_commits=(--not --remotes)

    # Names of files touched by the pushed commits.
    files="$(git log --name-only --pretty=format: "${_local_sha}" "${new_commits[@]}" 2>/dev/null | sort -u || true)"

    # 1) Filename heuristic: block secret-bearing file names/extensions.
    if [ -n "$files" ]; then
        bad_files="$(printf '%s\n' "$files" | grep -E "$SECRET_PATH_REGEX" || true)"
        if [ -n "$bad_files" ]; then
            echo "pre-push: refusing to push possible secret-bearing file(s):" >&2
            printf '%s\n' "$bad_files" >&2
            status=1
        fi
    fi

    # 2) Content scan: grep only ADDED lines of the pushed commits for the
    # secret pattern. We filter to `+` lines (excluding `+++` file headers) so
    # the gate fires only on lines a commit *introduces*, never on context
    # lines (a space prefix) or deletion lines (a `-` prefix). This matters:
    # (a) the repo's own security docs contain literal PEM/secret *examples*,
    #     and 3 lines of `git log -p` context would pull those in and block
    #     unrelated edits near them;
    # (b) deleting a secret line keeps it in the diff as a `-` line and would
    #     still match — which would block the very push that *removes* a
    #     secret and nudge contributors toward `--no-verify`.
    # Note: `git log -p` does not emit patches for merge commits, so a secret
    # introduced solely via a merge resolution is not scanned here. The
    # authoritative scan is TruffleHog in CI (.github/workflows/security-scan.yml),
    # which covers the full history; this hook is the fast local first line.
    if ! git log -p "${_local_sha}" "${new_commits[@]}" 2>/dev/null \
        | grep -E '^\+([^+]|$)' \
        | grep -E "$SECRET_PATTERN" >/dev/null; then
        :
    else
        echo "pre-push: possible secret detected in pushed commits — review before pushing:" >&2
        git log --name-only --pretty=format: "${_local_sha}" "${new_commits[@]}" 2>/dev/null | sort -u | head -20 >&2
        status=1
    fi
done

if [ "$status" -ne 0 ]; then
    echo "pre-push: blocked. Remove the secret, or push with --no-verify only after review." >&2
    exit 1
fi

exit 0